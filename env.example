# 12-Factor App Configuration (Config)
# Copiar a .env y completar valores reales

# Application
APP_NAME=pdf-text-extractor
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# MongoDB (NoSQL - Document Database)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=pdf_extractor
MONGODB_COLLECTION_DOCUMENTS=documents

# PDF Processing
MAX_PDF_SIZE_MB=10
ALLOWED_MIME_TYPES=application/pdf

# Checksum
CHECKSUM_ALGORITHM=SHA256